# ==========================================================
#  PistaGO — .gitignore
# ==========================================================
 
# ----- Gradle -----
.gradle/
build/
backend/.gradle/
backend/build/
backend/target/
 
# ----- Configuración local -----
local.properties
 
# ----- Logs / OS -----
*.log
 
# ----- Android Studio -----
captures/
.externalNativeBuild/
.cxx/
*.aab
*.apk
output-metadata.json
 
# ----- IntelliJ IDEA -----
*.iml
.idea/
misc.xml
deploymentTargetDropDown.xml
render.experimental.xml
 
# ----- Keystores -----
*.jks
*.keystore
 
# ----- Android Profiling -----
*.hprof
 
# ----- Compilados Java -----
*.jar
# Excepción: el wrapper de Gradle SÍ debe versionarse
!gradle/wrapper/gradle-wrapper.jar
!backend/gradle/wrapper/gradle-wrapper.jar
 
# ==========================================================
#  SECRETOS — NUNCA subir
# ==========================================================
*.env
google-services.json
firebase-service-account.json
application-prod.yml
application-prod.yaml
 
# Configuración con credenciales reales
application.yaml
application.yml
# Excepción: la plantilla de ejemplo SÍ se sube
!application.yaml.example